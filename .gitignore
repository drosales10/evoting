# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
**/node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
**/coverage/

# next.js
**/.next/
**/out/

# production
**/build/
**/dist/

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma

/docs/*
!/docs/Padron_Administrativo.md
!/docs/Ciclo_Electoral_Registro.md
!/docs/Registro_Planchas_Candidatos.md
/scripts
/internal-docs
!/scripts/
/scripts/*
!/scripts/reset-mintlify-cache.ps1
!/scripts/sync-mintlify-smyeg.mjs
!/scripts/guard-admin-geo-route-collisions.mjs
!/scripts/watch-admin-geo-route-collisions.ps1
!/internal-docs/
/internal-docs/*
!/internal-docs/agents/
!/internal-docs/agents/*.md
/public/uploads
# mobile build artifacts
*.apk
sataa-mobile-debug.apk
autolink-*.txt

# Squad: ignore runtime state (logs, inbox, sessions)
.squad/orchestration-log/
.squad/log/
.squad/decisions/inbox/
.squad/sessions/
# Squad: SubSquad activation file (local to this machine)
.squad-workstream

# Python
**/__pycache__/
*.py[cod]
**/.venv/
**/.pytest_cache/
**/.mypy_cache/
**/.ruff_cache/
**/*.egg-info/

# Tooling caches and coverage
**/.cache/
**/.turbo/
.coverage
.coverage.*
htmlcov/

/openspec
.openspec
/kiro
.kiro
