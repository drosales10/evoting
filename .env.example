# Connection to the existing PostgreSQL database. Do not run migrations until its schema is inspected.
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/evoting

# Backend
CORS_ORIGINS=["http://localhost:3000"]
JWT_SECRET=replace-with-a-long-random-secret
ACCESS_TOKEN_MINUTES=10
REFRESH_TOKEN_DAYS=7
SECURE_COOKIES=false
# Temporary local switch only; keep true outside development.
ADMIN_MFA_REQUIRED=true
# URL-safe base64 encoding of exactly 32 random bytes; keep outside the database.
MFA_ENCRYPTION_KEY=

# Optional explicit admin bootstrap for scripts/seed_admin.py; never use defaults.
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
SEED_ADMIN_NAME=
SEED_ADMIN_ORG_SLUG=
SEED_ADMIN_ORG_NAME=
SEED_ADMIN_ROLE=ELECTORAL_JUSTICE

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
