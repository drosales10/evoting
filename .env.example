# Connection to the existing PostgreSQL database. Do not run migrations until its schema is inspected.
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/evoting

# Backend
ENVIRONMENT=development
CORS_ORIGINS=["http://localhost:3000"]
JWT_SECRET=replace-with-a-long-random-secret
ACCESS_TOKEN_MINUTES=10
REFRESH_TOKEN_DAYS=7
SECURE_COOKIES=false
FORCE_HTTPS_REDIRECT=false
# Temporary local switch only; keep true outside development.
ADMIN_MFA_REQUIRED=true
# URL-safe base64 encoding of exactly 32 random bytes; keep outside the database.
MFA_ENCRYPTION_KEY=

# Production gates (keep ZKP false until audited)
ZKP_VERIFICATION_ENABLED=false
REQUIRE_DUAL_TALLY_APPROVAL=false
BALLOT_ISSUANCE_REQUIRED=true

# Optional explicit admin bootstrap for scripts/seed_admin.py; never use defaults.
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
SEED_ADMIN_NAME=
SEED_ADMIN_ORG_SLUG=
SEED_ADMIN_ORG_NAME=
SEED_ADMIN_ROLE=ELECTORAL_JUSTICE

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
# Development-only voter OTP pilot. Keep false unless explicitly testing locally.
# NEVER enable in production. Does not gate ballot cast anymore.
VOTER_TEST_MODE=false
VOTER_TEST_CODE=

# Transactional email delivery (Mailtrap or production provider)
MAILTRAP_API_TOKEN=
MAILTRAP_API_MODE=sending
APP_PUBLIC_URL=http://localhost:3000
SMTP_FROM="Entrega de OTP <no-reply@example.com>"
PASSWORD_RESET_TTL_HOURS=2
