# Connection to the existing PostgreSQL database. Do not run migrations until its schema is inspected.
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/evoting

# Backend
CORS_ORIGINS=["http://localhost:3000"]
JWT_SECRET=replace-with-a-long-random-secret
ACCESS_TOKEN_MINUTES=10
REFRESH_TOKEN_DAYS=7
SECURE_COOKIES=false

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
