DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/evoting
CORS_ORIGINS=["http://localhost:3000"]
# Development-only voter pilot; never enable as a production OTP provider.
VOTER_TEST_MODE=false
VOTER_TEST_CODE=

# Transactional email delivery (Mailtrap)
MAILTRAP_API_TOKEN=
MAILTRAP_API_MODE=sending
APP_PUBLIC_URL=http://localhost:3000
SMTP_FROM="Entrega de OTP <no-reply@example.com>"
PASSWORD_RESET_TTL_HOURS=2
